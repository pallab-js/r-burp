{
  "name": "r-burp",
  "version": "0.1.0",
  "private": true,
  "description": "A lightweight, secure, privacy-oriented desktop proxy toolkit",
  "license": "MIT",
  "scripts": {
    "dev": "cd src && npm run dev",
    "build": "cd src && npm run build",
    "lint": "cd src && npm run lint",
    "tauri": "cargo tauri",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "test": "cd src-tauri && cargo test",
    "clippy": "cd src-tauri && cargo clippy -- -D warnings",
    "audit": "cd src && npm audit && cd ../src-tauri && cargo audit"
  }
}
